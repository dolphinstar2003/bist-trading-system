# Risk Management
MAX_POSITION_SIZE=0.05  # %5
MAX_DAILY_LOSS=0.02     # %2
STOP_LOSS_MULTIPLIER=1.5
MAX_OPEN_POSITIONS=5

# Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_SERVER=
EMAIL_USERNAME=
EMAIL_PASSWORD=