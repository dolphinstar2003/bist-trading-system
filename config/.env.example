# AlgoLab API Credentials
ALGOLAB_API_KEY=API-YOUR_API_KEY_HERE
ALGOLAB_USERNAME=YOUR_TC_KIMLIK_NO
ALGOLAB_PASSWORD=YOUR_DENIZBANK_PASSWORD

# Trading Settings
TRADING_MODE=paper  # paper, live, backtest
MIN_VOLUME=1000000
